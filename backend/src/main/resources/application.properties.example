# Copy to application.properties (or set environment variables) before running.
#
# Required environment variables:
# - DB_USERNAME
# - DB_PASSWORD
# - JWT_SECRET
# - MAIL_USERNAME
# - MAIL_PASSWORD
# - GEMINI_API_KEY

DB_USERNAME=root
DB_PASSWORD=your_mysql_password
JWT_SECRET=replace_with_secure_random_secret
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
GEMINI_API_KEY=your_gemini_api_key
FILE_BASE_URL=http://localhost:8080

server.port=8080

spring.datasource.url=jdbc:mysql://localhost:3306/suhada_furniture
spring.datasource.username=root
spring.datasource.password=${DB_PASSWORD}

jwt.secret=${JWT_SECRET}
jwt.expiration=86400000

spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=suhadafurnituresl@gmail.com
spring.mail.password=${MAIL_PASSWORD}

gemini.api.key=${GEMINI_API_KEY}
gemini.api.base-url=https://generativelanguage.googleapis.com/v1beta
gemini.model.text=gemini-2.5-flash
gemini.model.vision=gemini-2.5-flash
gemini.temperature=0.7
gemini.max.tokens=2048
